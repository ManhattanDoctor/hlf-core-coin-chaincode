{
    "name": "@hlf-core/coin-chaincode",
    "version": "3.6.21",
    "description": "TypeScript library for token management on the Hyperledger Fabric chaincode side: accounts, emission, transfers, hold and burning with event dispatching",
    "main": "./cjs/public-api.js",
    "module": "./esm/public-api.js",
    "exports": {
        ".": {
            "import": "./esm/public-api.js",
            "require": "./cjs/public-api.js"
        }
    },
    "author": {
        "name": "Renat Gubaev",
        "email": "renat.gubaev@gmail.com"
    },
    "license": "ISC",
    "dependencies": {
        "@hlf-core/chaincode": "~3.6.6",
        "@hlf-core/coin": "~3.2.34"
    },
    "devDependencies": {
        "gulp-npm-module-publisher": "~3.0.5"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ManhattanDoctor/hlf-core-coin-chaincode.git"
    },
    "keywords": [
        "hyperledger",
        "hyperledger-fabric",
        "fabric",
        "chaincode",
        "smart-contracts",
        "blockchain",
        "token",
        "coin",
        "digital-asset",
        "typescript"
    ],
    "bugs": {
        "url": "https://github.com/ManhattanDoctor/hlf-core-coin-chaincode/issues"
    },
    "homepage": "https://github.com/ManhattanDoctor/hlf-core-coin-chaincode#readme"
}
